# Пример конфигурации окружения (Environment configuration example)
# Скопируй в .env и заполни реальными значениями (Copy to .env and fill with real values)

# Telegram Bot token от @BotFather (Telegram Bot token from @BotFather)
TELEGRAM_BOT_TOKEN=

# Open-Meteo не требует ключа (Open-Meteo does not require a key)
# OPEN_METEO_API_KEY=

# GitHub token для пуша (GitHub token for push)
GITHUB_TOKEN=

# === Логирование и аудит (Logging and audit) ===
# Уровень логирования: DEBUG, INFO, WARNING, ERROR (Log level)
LOG_LEVEL=info

# Формат логов: text (development) или json (production) (Log format)
LOG_FORMAT=text

# Директория для лог-файлов (Logs directory)
LOGS_DIR=logs

# Порог медленного запроса в мс (Slow request threshold in ms)
SLOW_REQUEST_MS=1000

# === Сессии и аутентификация (Sessions and authentication) ===
# Секретный ключ для подписи session-cookie (Secret key for signing session cookies)
# Сгенерируй случайную строку: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Базовый URL веб-приложения для ссылок из Telegram (Web app base URL for Telegram links)
WEB_APP_URL=http://localhost:8000

# === База данных (Database) ===
# SQLite для локальной разработки, PostgreSQL для Docker/production (SQLite for local dev, PostgreSQL for Docker)
# Локально: DATABASE_URL=sqlite:///running_coach.db
# Docker:   DATABASE_URL=postgresql://running_coach:PASSWORD@db:5432/running_coach
DATABASE_URL=sqlite:///running_coach.db

# === PostgreSQL (для Docker) (PostgreSQL — for Docker) ===
# Пароль для PostgreSQL в Docker (Password for PostgreSQL in Docker)
# Сгенерируй: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=change-me-in-production
