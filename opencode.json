{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-pro",
      "description": "Оркестратор — координирует полный цикл исправления багов через субагентов",
      "prompt": "{file:.opencode/agents/orchestrator.md}",
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "task": {"*": "allow"},
        "bash": {
          "git *": "allow",
          "*": "deny"
        },
        "edit": "deny",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  }
}
